<%- include('partials/head') %>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": "<%= recipe.name %>",
  "image": "<%= recipe.image %>",
  "author": {
    "@type": "Person",
    "name": "Marcus Cole"
  },
  "datePublished": "<%= recipe.datePublished %>",
  "description": "<%= recipe.description %>",
  "prepTime": "<%= recipe.prepTime %>",
  "cookTime": "<%= recipe.cookTime %>",
  "totalTime": "<%= recipe.totalTime %>",
  "recipeYield": "<%= recipe.recipeYield %>",
  "recipeCategory": "<%= recipe.recipeCategory %>",
  "recipeCuisine": "<%= recipe.recipeCuisine %>",
  "keywords": "<%= recipe.keywords.join(', ') %>",
  "recipeIngredient": <%- JSON.stringify(recipe.recipeIngredient.filter(i => !i.startsWith('---'))) %>,
  "recipeInstructions": [
    <% recipe.recipeInstructions.forEach((step, i) => { %>
    {
      "@type": "HowToStep",
      "position": <%= i + 1 %>,
      "text": "<%= step.text.replace(/"/g, '\\"') %>"
    }<%= i < recipe.recipeInstructions.length - 1 ? ',' : '' %>
    <% }); %>
  ]<% if (recipe.nutrition) { %>,
  "nutrition": {
    "@type": "NutritionInformation",
    "calories": "<%= recipe.nutrition.calories %> calories",
    "fatContent": "<%= recipe.nutrition.fatContent %>",
    "proteinContent": "<%= recipe.nutrition.proteinContent %>",
    "carbohydrateContent": "<%= recipe.nutrition.carbohydrateContent %>"
  }
  <% } %>
}
</script>

<%
function formatTime(iso) {
  if (!iso) return '';
  const match = iso.match(/PT(?:(\d+)H)?(?:(\d+)M)?/);
  if (!match) return '';
  const hours = parseInt(match[1] || 0);
  const mins = parseInt(match[2] || 0);
  if (hours && mins) return `${hours}h ${mins}m`;
  if (hours) return `${hours}h`;
  return `${mins} min`;
}

function formatDate(dateStr) {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const recipyIds = {
  // Add recipe slug -> Recipy ID mappings here after importing
};

const recipyId = recipyIds[recipe.slug];
%>

<article class="recipe-detail">
  <div class="recipe-detail__container">

    <nav class="breadcrumb">
      <a href="/">Recipes</a> <span>/</span> <span><%= recipe.name %></span>
    </nav>

    <header class="recipe-detail__header">
      <div class="recipe-detail__tags">
        <span class="recipe-detail__tag"><%= recipe.recipeCuisine %></span>
        <span class="recipe-detail__tag"><%= recipe.difficulty %></span>
        <% if (recipe.nutrition && recipe.nutrition.proteinContent) { %>
        <span class="recipe-detail__tag recipe-detail__tag--protein"><%= recipe.nutrition.proteinContent %> protein</span>
        <% } %>
      </div>
      <h1 class="recipe-detail__title"><%= recipe.name %></h1>
      <p class="recipe-detail__headline"><%= recipe.headline %></p>
      <p class="recipe-detail__description"><%= recipe.description %></p>
    </header>

    <div class="recipe-detail__info">
      <div class="recipe-detail__info-item">
        <span class="recipe-detail__info-label">Prep</span>
        <span class="recipe-detail__info-value"><%= formatTime(recipe.prepTime) %></span>
      </div>
      <div class="recipe-detail__info-item">
        <span class="recipe-detail__info-label">Cook</span>
        <span class="recipe-detail__info-value"><%= formatTime(recipe.cookTime) %></span>
      </div>
      <div class="recipe-detail__info-item">
        <span class="recipe-detail__info-label">Total</span>
        <span class="recipe-detail__info-value"><%= formatTime(recipe.totalTime) %></span>
      </div>
      <div class="recipe-detail__info-item">
        <span class="recipe-detail__info-label">Servings</span>
        <span class="recipe-detail__info-value"><%= recipe.recipeYield.replace(' servings', '') %></span>
      </div>
    </div>

    <div class="recipe-detail__byline">
      By Marcus Cole &middot; <%= formatDate(recipe.datePublished) %>
    </div>

    <div class="recipe-detail__hero">
      <img src="<%= recipe.image %>" alt="<%= recipe.name %>" class="recipe-detail__hero-image">
    </div>

    <% if (recipe.story && recipe.story.length > 0) { %>
    <section class="recipe-detail__story">
      <% recipe.story.forEach(paragraph => { %>
      <p><%= paragraph %></p>
      <% }); %>
    </section>
    <% } %>

    <section class="recipe-card-full">
      <h2 class="recipe-card-full__title"><%= recipe.name %></h2>

      <% if (recipe.nutrition) { %>
      <div class="recipe-card-full__macros">
        <div class="macro">
          <span class="macro__value"><%= recipe.nutrition.calories %></span>
          <span class="macro__label">Calories</span>
        </div>
        <div class="macro">
          <span class="macro__value"><%= recipe.nutrition.proteinContent %></span>
          <span class="macro__label">Protein</span>
        </div>
        <div class="macro">
          <span class="macro__value"><%= recipe.nutrition.carbohydrateContent %></span>
          <span class="macro__label">Carbs</span>
        </div>
        <div class="macro">
          <span class="macro__value"><%= recipe.nutrition.fatContent %></span>
          <span class="macro__label">Fat</span>
        </div>
      </div>
      <% } %>

      <div class="recipe-card-full__body">
        <div class="recipe-card-full__ingredients">
          <h3>Ingredients</h3>
          <ul>
            <% recipe.recipeIngredient.forEach(ingredient => { %>
              <% if (ingredient.startsWith('---')) { %>
              <li class="ingredient-section"><%= ingredient.replace('---', '').trim() %></li>
              <% } else { %>
              <li>
                <label class="ingredient-check">
                  <input type="checkbox">
                  <span><%= ingredient %></span>
                </label>
              </li>
              <% } %>
            <% }); %>
          </ul>
        </div>

        <div class="recipe-card-full__instructions">
          <h3>Instructions</h3>
          <ol>
            <% recipe.recipeInstructions.forEach(step => { %>
            <li><%= step.text %></li>
            <% }); %>
          </ol>
        </div>
      </div>

      <% if (recipyId) { %>
      <div class="recipe-detail__widget">
        <recipy-shop data-recipe-id="<%= recipyId %>" theme="auto"></recipy-shop>
      </div>
      <% } %>
    </section>

  </div>
</article>

<%- include('partials/footer') %>
